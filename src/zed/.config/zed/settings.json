// Zed settings
// See https://zed.dev/docs/configuring-zed
// Run `zed: open default settings` to check the default values

{
  // Keymap
  "base_keymap": "VSCode",
  "vim_mode": true,

  // Theme
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "One Dark",
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Colored Zed Icons Theme Dark",
    "dark": "Colored Zed Icons Theme Dark",
  },
  "buffer_font_family": "CaskaydiaMono Nerd Font Mono",
  "buffer_font_size": 16,
  "ui_font_family": "CaskaydiaMono Nerd Font Mono",
  "ui_font_size": 16,
  "show_whitespaces": "boundary",
  "minimap": {
    "show": "never",
  },

  // Utils
  "cli_default_open_behavior": "new_window",

  // Git
  "diff_view_style": "unified",
  "git_panel": {
    "dock": "left",
    "sort_by_path": true,
    "tree_view": false,
  },

  // Panels
  "collaboration_panel": {
    "dock": "right",
    "button": false,
  },
  "outline_panel": {
    "dock": "right",
  },
  "project_panel": {
    "dock": "left",
    "hide_gitignore": true,
  },

  // Help
  "inlay_hints": {
    "enabled": false,
    "show_type_hints": false,
    "show_parameter_hints": false,
    "show_value_hints": false,
    "show_other_hints": false,
  },

  // AI Prediction
  "edit_predictions": {
    "mode": "eager",
  },

  // AI Agents
  "agent": {
    "dock": "right",
  },
}
